# Force LF line endings for source code and license text. Prevents CRLF
# noise on Windows clones (M11 Pre-Task 0 found 12 files "modified"
# purely due to line-ending differences).
*.py        text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.lock      text eol=lf
LICENSE     text eol=lf
.env.example text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf
