# --- Telegram ---
TELEGRAM_API_ID=00000000
TELEGRAM_API_HASH=replace_me
TELEGRAM_PHONE=+10000000000
TELEGRAM_SESSION_STRING=
TELEGRAM_TARGET_CHAT=@analyst_channel
TELEGRAM_SELF_DM_NOTIFICATIONS=true

# --- OlympTrade ---
# See PRD §4.6 FR-6.6: app refuses to start with OLYMP_ACCOUNT_GROUP=real + DRY_RUN=false.
# Real-money trading is a v2 feature, gated behind a 7-day clean demo soak test.
OLYMP_ACCESS_TOKEN=replace_me
OLYMP_ACCOUNT_GROUP=demo
OLYMP_ACCOUNT_ID=

# --- Database ---
# Local dev: postgresql://copier:copier@localhost:5432/copier
# Railway: auto-injected by the Postgres add-on.
DATABASE_URL=postgresql://user:pass@localhost:5432/copier

# --- Trading ---
DRY_RUN=true
REQUIRE_CONFIRM=false
AMOUNT_INITIAL=2.00
AMOUNT_GALE1=4.00
AMOUNT_GALE2=8.00
EXPIRATION_SECONDS=300
DAILY_LOSS_LIMIT=0.00
DAILY_TRADE_LIMIT=0
# Daily drawdown limit. M6 treats this as a USD threshold (not a true % of
# starting balance): the signal-copier halts when realized_pnl <= -N (USD).
# M8 will switch to a true percentage-of-balance check once
# OlympTradeBroker.balance() is wired in at startup.
DAILY_DRAWDOWN_PCT=0

# --- Schedule / Timezone ---
TIMEZONE=America/Sao_Paulo
TRIGGER_SKEW_TOLERANCE_SECONDS=2.0
LOG_PATH=./logs/signal_copier.log
